# Postgres compartilhado (mesmo do core; schema public é do core, tenant_<id> é dos produtos)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sapienza

# Porta do serviço
PORT=8081

# Segredo do JWT curto emitido pelo core (deve bater com PRODUCT_JWT_SECRET do core)
PRODUCT_JWT_SECRET=troque-por-um-segredo-forte

# AES-256-GCM p/ segredos por-tenant (32 bytes base64): openssl rand -base64 32
MARGOT_ENC_KEY=

# Evolution API (servidor global da Sapienza; instância roteia por tenant)
EVOLUTION_API_URL=https://evolution.suaempresa.com
EVOLUTION_API_KEY=
EVOLUTION_WEBHOOK_SECRET=

# Claude (se ausente, o bot responde só com o fallback do tenant)
ANTHROPIC_API_KEY=
